APP_NAME="SquadUp API"
ENVIRONMENT=development
DATABASE_URL=sqlite:///./squadup.db
# Em produção (Railway), a variável DATABASE_URL é injetada automaticamente pelo addon
# de Postgres, no formato postgresql://... — trocar o prefixo para postgresql+psycopg://
# para usar o driver psycopg (ver requirements.txt e README.md "Deploy").
# DATABASE_URL=postgresql+psycopg://user:password@host:5432/railway
SECRET_KEY=change-me-in-.env
ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Lista de origins separados por vírgula. Se omitido, usa os defaults de dev
# (localhost:8081, localhost:19006, exp://localhost:19000).
# Em produção, incluir a URL real do app publicado (Expo/EAS) assim que existir.
# CORS_ORIGINS=http://localhost:8081,http://localhost:19006,exp://localhost:19000
